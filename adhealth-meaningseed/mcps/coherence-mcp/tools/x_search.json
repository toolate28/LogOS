{
  "name": "x_search",
  "description": "Search recent X posts via Twitter API v2. Requires X_BEARER_TOKEN.",
  "inputSchema": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "X search query (e.g. from:reson8Labs TriWeavon)"
      },
      "maxResults": {
        "type": "number",
        "description": "Max results (default 20)"
      }
    },
    "required": [
      "query"
    ]
  }
}